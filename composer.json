{
    "name": "unoforge/flexiwind-cli",
    "description": "Flexiwind Artisan commands",
    "version": "1.0.5",
    "type": "library",
    "require": {
        "php": "^8.2",
        "unoforge/flexi-core": "^1.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "laravel/prompts": "^0.3.10",
        "symfony/console": "^7.3 || ^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "FlexiLaravel\\": "src/"
        }
    },
    "license": "MIT",
    "extra": {
        "laravel": {
            "providers": [
                "FlexiLaravel\\FlexiServiceProvider"
            ]
        }
    }
}
